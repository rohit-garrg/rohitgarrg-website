---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container-page footer-inner">
    <p class="copyright">&copy; {currentYear} Rohit Garg</p>
    <ul class="social-links">
      <li><a href="https://www.linkedin.com/in/rohitgarrg/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
      <li><a href="mailto:rohitgarrg@gmail.com">Email</a></li>
    </ul>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: var(--space-xl) 0;
    margin-top: auto;
    background-color: var(--bg-primary);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .copyright {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--text-meta);
  }

  .social-links {
    display: flex;
    list-style: none;
    gap: var(--space-md);
  }

  .social-links a {
    color: var(--text-secondary);
    font-size: var(--text-meta);
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .social-links a:hover {
    color: var(--accent);
  }

</style>

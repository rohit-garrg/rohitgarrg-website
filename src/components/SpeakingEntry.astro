---
interface Props {
  slug: string;
  event: string;
  title: string;
  month: string;
  description: string;
}

const { slug, event, title, month, description } = Astro.props;
---

<div class="timeline-entry">
  <div class="timeline-month">{month}</div>
  <h3><a href={`/speaking/${slug}/`}>{event}</a></h3>
  <p class="talk-title">{title}</p>
  <p class="talk-desc">{description}</p>
  <a href={`/speaking/${slug}/`} class="view-link">View details →</a>
</div>

<style>
  .timeline-entry {
    position: relative;
    padding-bottom: var(--space-xl);
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-lg) - 5px);
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    border: 2px solid var(--bg-primary);
  }

  .timeline-month {
    font-size: var(--text-meta);
    color: var(--text-tertiary);
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  h3 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 500;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
  }

  h3 a {
    color: inherit;
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent);
  }

  .talk-title {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: var(--space-xs);
  }

  .talk-desc {
    font-size: var(--text-meta);
    color: var(--text-tertiary);
    line-height: 1.5;
    margin-bottom: var(--space-sm);
  }

  .view-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .view-link:hover {
    color: var(--accent-hover);
  }

  @media (max-width: 768px) {
    .timeline-entry::before {
      left: calc(-1 * var(--space-md) - 5px);
    }
  }
</style>

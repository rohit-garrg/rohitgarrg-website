---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

// Get articles sorted by date (newest first), limit to 3
const allArticles = await getCollection('writing');
const sortedArticles = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestArticles = sortedArticles.slice(0, 3);

function getReadingTime(article: typeof latestArticles[0]): number {
  return Math.ceil((article.body ?? '').split(/\s+/).length / 200);
}

const featuredArticle = latestArticles[0];
const gridArticles = latestArticles.slice(1);

// WebSite schema for homepage
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Rohit Garg",
  "description": "Head of Product & Design at Times of India. Writing about product management, leadership, and AI tools.",
  "url": "https://www.rohitgarrg.com",
  "author": {
    "@type": "Person",
    "name": "Rohit Garg",
    "jobTitle": "Head of Product & Design",
    "worksFor": {
      "@type": "Organization",
      "name": "Times of India"
    }
  }
};
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <div class="container-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1>Rohit Garg</h1>
        <p class="subtitle">Head of Product & Design, Times of India</p>
        <p class="bio">14 years building products at scale.<br />Writing about what actually works.</p>
        <div class="hero-links">
          <a href="https://www.linkedin.com/in/rohitgarrg/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:rohitgarrg@gmail.com">Email</a>
        </div>
      </div>
    </section>

    <!-- Latest Writing Section -->
    <section class="section">
      <div class="section-header">
        <h2>Latest Writing</h2>
        <a href="/writing" class="view-all">View all →</a>
      </div>
      {featuredArticle && (
        <ArticleCard
          title={featuredArticle.data.title}
          description={featuredArticle.data.description}
          category={featuredArticle.data.category}
          date={featuredArticle.data.date}
          slug={featuredArticle.id.replace(/\.md$/, '')}
          leadImage={featuredArticle.data.leadImage}
          variant="featured"
          readingTime={getReadingTime(featuredArticle)}
        />
      )}
      {gridArticles.length > 0 && (
        <div class="articles-grid">
          {gridArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              category={article.data.category}
              date={article.data.date}
              slug={article.id.replace(/\.md$/, '')}
              leadImage={article.data.leadImage}
              variant="grid"
              readingTime={getReadingTime(article)}
            />
          ))}
        </div>
      )}
    </section>

    <!-- Projects Section -->
    <section class="section">
      <div class="section-header">
        <h2>Projects</h2>
        <a href="/projects" class="view-all">View all →</a>
      </div>
      <div class="projects-grid">
        <a href="/projects/solar-system" class="project-card">
          <div class="project-image">
            <img src="/images/projects/solar-system-og.webp" alt="Solar System Explorer — interactive 3D solar system" loading="lazy" width="1120" height="630" />
          </div>
          <div class="project-card-body">
            <h3>Solar System Explorer</h3>
            <p>An interactive 3D solar system for kids. Tap planets, discover fun facts, and fly a spacecraft between worlds.</p>
            <div class="project-tech">
              <span class="tech-pill">React</span>
              <span class="tech-pill">Three.js</span>
            </div>
            <div class="project-process">
              <span class="ai-pill">Built with AI</span>
            </div>
            <span class="project-link">View project →</span>
          </div>
        </a>
        <a href="/projects/office-survivors" class="project-card">
          <div class="project-image">
            <img src="/images/projects/office-survivors-og.webp" alt="Office Survivors game screenshot" loading="lazy" width="1120" height="630" />
          </div>
          <div class="project-card-body">
            <h3>Office Survivors</h3>
            <p>A satirical pixel-art browser game about surviving corporate life. Deliver tasks, dodge chaos agents, and climb from intern to CEO.</p>
            <div class="project-tech">
              <span class="tech-pill">Phaser 3</span>
            </div>
            <div class="project-process">
              <span class="ai-pill">Built with AI</span>
            </div>
            <span class="project-link">View project →</span>
          </div>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-3xl) 0 var(--space-2xl) 0;
  }

  .hero-content {
    max-width: 66%;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-hero);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }

  .subtitle {
    font-size: 20px;
    font-weight: 300;
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .bio {
    font-size: var(--text-body);
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .hero-links {
    display: flex;
    gap: var(--space-md);
  }

  .hero-links a {
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
  }

  .hero-links a:hover {
    text-decoration: underline;
  }

  /* Sections */
  .section {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
    gap: var(--space-md);
  }

  .section-header h2 {
    font-family: var(--font-heading);
    font-weight: 500;
    margin-bottom: 0;
  }

  .view-all {
    font-size: var(--text-tag);
    font-weight: 500;
    white-space: nowrap;
  }

  /* Articles grid */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  /* Projects grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .project-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: var(--bg-secondary);
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--border-hover);
  }

  .project-card:hover h3 {
    color: var(--accent);
  }

  .project-image {
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.03);
  }

  .project-card-body {
    padding: var(--space-lg);
  }

  .project-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 500;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .project-card p {
    margin-bottom: var(--space-sm);
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .project-tech {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .tech-pill {
    font-size: var(--text-tag);
    padding: 4px 8px;
    background: var(--bg-tertiary);
    border-radius: 4px;
    color: var(--text-secondary);
  }

  .project-process {
    margin-bottom: var(--space-sm);
  }

  .ai-pill {
    font-size: var(--text-tag);
    padding: 4px 10px;
    background: var(--accent-subtle);
    color: var(--accent);
    border-radius: 4px;
  }

  .project-link {
    font-size: 14px;
    color: var(--accent);
    font-weight: 500;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-3xl) 0 var(--space-2xl) 0;
    }

    .hero-content {
      max-width: 100%;
    }

    .subtitle {
      font-size: 16px;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: row;
    }
  }
</style>

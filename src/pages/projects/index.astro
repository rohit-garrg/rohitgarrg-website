---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Projects - Rohit Garg"
  description="Side projects, experiments, and hobby builds."
>
  <div class="container">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="page-description">Side projects, experiments, and things I'm tinkering with.</p>
    </header>

    <div class="projects-grid">
      <a href="/projects/solar-system" class="project-card">
        <div class="project-image">
          <img src="/images/projects/solar-system-og.webp" alt="Solar System Explorer screenshot" loading="lazy" width="1200" height="675" />
        </div>
        <div class="project-card-body">
          <h2>Solar System Explorer</h2>
          <p class="project-description">An interactive 3D solar system for kids. Tap planets, discover fun facts, fly a spacecraft between worlds, and explore all 22 celestial bodies.</p>
          <div class="project-meta">
            <span class="project-tag">React + Three.js</span>
            <span class="project-tag">Built with AI</span>
          </div>
        </div>
      </a>

      <a href="/projects/office-survivors" class="project-card">
        <div class="project-image">
          <img src="/images/projects/office-survivors-og.webp" alt="Office Survivors game screenshot" loading="lazy" width="1200" height="675" />
        </div>
        <div class="project-card-body">
          <h2>Office Survivors</h2>
          <p class="project-description">A satirical pixel-art browser game about surviving corporate life. Deliver tasks, dodge chaos agents, and climb from intern to CEO.</p>
          <div class="project-meta">
            <span class="project-tag">Phaser 3</span>
            <span class="project-tag">Built with AI</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  .page-header h1 {
    margin-bottom: var(--space-xs);
  }

  .page-description {
    color: var(--text-secondary);
    font-size: 20px;
    font-weight: 300;
    margin-bottom: 0;
  }

  .projects-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .project-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .project-card:hover {
    border-color: var(--border-hover);
  }

  .project-image {
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.03);
  }

  .project-card-body {
    padding: var(--space-lg);
  }

  .project-card h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 500;
    margin-bottom: var(--space-xs);
    transition: color 0.2s ease;
  }

  .project-card:hover h2 {
    color: var(--accent);
  }

  .project-description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
  }

  .project-meta {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .project-tag {
    font-size: var(--text-tag);
    padding: 2px 8px;
    background: var(--bg-tertiary);
    border-radius: 4px;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--space-lg) 0;
    }
  }
</style>
